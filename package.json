{
  "name": "tailwind-dark-invert",
  "version": "0.2.1",
  "description": "Auto-invert Tailwind CSS v4 palette colors in dark mode. One import, zero config.",
  "main": "index.css",
  "style": "index.css",
  "exports": {
    ".": "./index.css"
  },
  "bin": {
    "tailwind-dark-invert": "./bin.mjs"
  },
  "files": [
    "index.css",
    "bin.mjs"
  ],
  "scripts": {
    "generate": "node scripts/generate.mjs"
  },
  "devDependencies": {
    "tailwindcss": "^4"
  },
  "keywords": [
    "tailwindcss",
    "tailwind",
    "dark-mode",
    "dark",
    "css",
    "colors",
    "invert",
    "palette"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/gonzaloandresoto/tailwind-dark-invert.git"
  },
  "license": "MIT"
}
